# =============================================================
# Sprawl hybrid .gitignore
# Public on GitHub: the static site (HTML, JS, fonts at repo root)
# and the agent kit. Everything else is private to the operator.
# =============================================================

# --- Secrets ---
.env
*.env

# --- Private dev infrastructure (stay local, never pushed) ---
contracts/
api/
subgraph/

# --- Internal planning docs ---
MAINNET_PLAN.md
OPERATIONS.md
EMERGENCY.md
CONCEPT.md
PLAN.md
README.md.dev

# --- Kit local state ---
kit/.env
kit/config.json
kit/workspace/
kit/__pycache__/
kit/references/__pycache__/

# --- Python ---
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# --- Node (if tooling ever appears) ---
node_modules/
package-lock.json

# --- Editor / IDE ---
.vscode/
.idea/

# --- OS ---
.DS_Store
Thumbs.db

# --- Local tool installs ---
.tools/
