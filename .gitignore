# =============================================================
# Sprawl hybrid .gitignore
# Public on GitHub: the static site only (HTML, JS, fonts at repo root).
# The agent kit moved to its own repo (sprawl-agent-kit) and lives at
# /Users/ausae/Desktop/sprawl_agent_kit. The local kit-archive/ here is
# the frozen pre-split snapshot, kept on disk only.
# Everything else is private to the operator.
# =============================================================

# --- Secrets ---
.env
*.env

# --- Private dev infrastructure (stay local, never pushed) ---
contracts/
api/
subgraph/

# --- Agent kit (moved to its own repo) ---
kit/
kit-archive/
skill.md

# --- Internal planning docs ---
MAINNET_PLAN.md
OPERATIONS.md
EMERGENCY.md
CONCEPT.md
PLAN.md
VISUAL.md
visual.md
README.md.dev
NARRATION_IMPLEMENTATION.md

# --- Design / mockups (operator-only; not part of the public site) ---
mockups/
*.png
*.jpg
*.jpeg
*.psd
*.fig
*.sketch

# --- Claude Code workspace state ---
.claude/

# --- Editor scratch + backup files ---
*.swp
*.swo
*~
*.bak
*.tmp
*.orig

# --- Forge / SAM build artifacts (defense-in-depth; the parent dirs
#     contracts/ and api/ are already ignored, but if anything ever
#     lands at repo root by mistake these patterns catch it) ---
out/
cache/
broadcast/
.aws-sam/

# --- Python ---
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# --- Node (if tooling ever appears) ---
node_modules/
package-lock.json

# --- Editor / IDE ---
.vscode/
.idea/

# --- OS ---
.DS_Store
Thumbs.db

# --- Local tool installs ---
.tools/
